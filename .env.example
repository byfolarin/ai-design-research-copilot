# Copy this file to .env.local and fill in your keys.
# .env.local is git-ignored, so your real keys never get committed.

# Required for live AI reports (Claude). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: live Mobbin screens in reports
MOBBIN_MCP_TOKEN=
# MOBBIN_MCP_URL=https://api.mobbin.com/mcp

# Optional: live Figma frame reading (also include a figma.com link in your prompt)
FIGMA_TOKEN=
